#!/usr/bin/env bash
set -euo pipefail

IMAGE=dev-container

usage() {
	echo "Usage: $0 [-p port1,port2,...] [-v host:container ...] [--home dir]" >&2
}

PORTS=""
MOUNT_SPECS=()
HOME_DIR_FLAG=""
while [[ $# -gt 0 ]]; do
	case "$1" in
		-p) [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; usage; exit 1; }
			PORTS="$2"; shift 2 ;;
		-p*) PORTS="${1#-p}"; shift ;;
		-v) [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; usage; exit 1; }
			MOUNT_SPECS+=("$2"); shift 2 ;;
		-v*) MOUNT_SPECS+=("${1#-v}"); shift ;;
		--home) [[ $# -ge 2 ]] || { echo "Error: $1 requires an argument" >&2; usage; exit 1; }
			HOME_DIR_FLAG="$2"; shift 2 ;;
		--home=*) HOME_DIR_FLAG="${1#--home=}"; shift ;;
		-h | --help) usage; exit 0 ;;
		--) shift; break ;;
		-*) echo "Error: unknown option '$1'" >&2; usage; exit 1 ;;
		*) break ;;
	esac
done

# Resolve the persistent home directory: --home flag wins over the HOME_DIR
# environment variable, which wins over the default. A relative or ~ path is
# resolved to absolute so docker doesn't treat it as a named volume.
HOME_DIR="${HOME_DIR_FLAG:-${HOME_DIR:-$HOME/.dev-container-home}}"
case "$HOME_DIR" in
	"~")   HOME_DIR="$HOME" ;;
	"~/"*) HOME_DIR="$HOME/${HOME_DIR#\~/}" ;;
esac
[[ "$HOME_DIR" = /* ]] || HOME_DIR="$(realpath -m -- "$HOME_DIR")"

PORT_ARGS=()
PORT_SUFFIX=""
if [[ -n "$PORTS" ]]; then
	IFS=',' read -ra PORT_LIST <<< "$PORTS"
	for port in "${PORT_LIST[@]}"; do
		PORT_ARGS+=(-p "${port}:${port}")
	done
	PORT_SUFFIX="-$(echo "$PORTS" | tr ',' '-')"
fi

# Build extra bind-mount args. Each spec is host:container[:opts] (docker -v
# format). The host side is normalised so relative/~ paths don't silently turn
# into named volumes, while absolute paths and bare names pass through as-is.
MOUNT_ARGS=()
for spec in ${MOUNT_SPECS[@]+"${MOUNT_SPECS[@]}"}; do
	if [[ "$spec" != *:* ]]; then
		echo "Error: -v expects host:container, got '$spec'" >&2
		usage
		exit 1
	fi
	src="${spec%%:*}"
	rest="${spec#*:}"
	case "$src" in
		"~")                    src="$HOME" ;;
		"~/"*)                  src="$HOME/${src#\~/}" ;;
		"." | ".." | "./"* | "../"*) src="$(realpath -m "$src")" ;;
	esac
	MOUNT_ARGS+=(-v "${src}:${rest}")
done

CONTAINER_NAME="dev-$(echo "$PWD" | md5sum | cut -c1-12)${PORT_SUFFIX}"

# Ensure persistent home exists
mkdir -p "$HOME_DIR" "$HOME_DIR/go"

if docker inspect --format='{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null | grep -q true; then
	echo "Attaching to running container $CONTAINER_NAME..."
	if [[ ${#MOUNT_ARGS[@]} -gt 0 ]]; then
		echo "warning: container $CONTAINER_NAME is already running; -v mounts are ignored (docker cannot add mounts to a running container)" >&2
	fi
	docker exec -it "$CONTAINER_NAME" bash
else
	echo "Starting new container $CONTAINER_NAME..."
	docker run -it --rm \
		--name "$CONTAINER_NAME" \
		-v "$HOME_DIR:/home/developer" \
		-v "$PWD:/workspace" \
		${MOUNT_ARGS[@]+"${MOUNT_ARGS[@]}"} \
		${PORT_ARGS[@]+"${PORT_ARGS[@]}"} \
		--network services \
		"$IMAGE"
fi
